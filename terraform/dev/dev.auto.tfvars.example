# File: terraform/dev/dev.auto.tfvars.example
# Copy to dev.auto.tfvars and fill in. dev.auto.tfvars is git-ignored if it
# ever carries anything sensitive; these values are not secrets, but keep the
# real file out of version control if your project treats project_id as private.

project_id = "haffey-sofia-dev" # REPLACE with the real dev project id

region = "us-east4"

zone = "us-east4-a" # dev cluster is zonal (single node); regional HA is a deferred prod topology

master_authorized_cidrs = [
  # REPLACE with the CIDR(s) you administer the cluster from (e.g. your VPN egress).
  { cidr_block = "203.0.113.0/32", display_name = "operator-workstation" },
]
