# File: knowledge_service/.env.example
# Service: knowledge-service
# Author: Haffey Enterprises LLC
# Created: 2026-07-21
# Revised: 2026-07-21
# Description: Committed schema of the environment knowledge-service reads
#   (SDD-001 §4.6). Values here are local-development placeholders only. The
#   real `.env` is git-ignored; in deployed environments every value below
#   arrives as an environment variable, with credentials delivered from GCP
#   Secret Manager under Workload Identity Federation — no key files, and no
#   credentials in source, logs, errors, or responses.

# --- Service identity ------------------------------------------------------
KS_SERVICE_NAME=knowledge-service
KS_SERVICE_VERSION=0.1.0
KS_APP_ENV=development

# --- HTTP ------------------------------------------------------------------
# Cloud Run injects PORT; 8080 is the default when it is absent.
PORT=8080

# --- Logging ---------------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR | CRITICAL
KS_LOG_LEVEL=INFO

# --- Neo4j (the graph system of record; this service is its sole driver holder)
KS_NEO4J_URI=bolt://localhost:7687
KS_NEO4J_DATABASE=neo4j
KS_NEO4J_USERNAME=neo4j
# Secret-managed in deployed environments. Never commit a real value.
KS_NEO4J_PASSWORD=
KS_NEO4J_MAX_CONNECTION_POOL_SIZE=50
KS_NEO4J_CONNECTION_ACQUISITION_TIMEOUT_SECONDS=60.0
